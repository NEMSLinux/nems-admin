#!/bin/bash
echo $0 > /var/www/html/userfiles/nems-build.cur

if [[ -d /usr/lib/aarch64-linux-gnu ]]; then
  # On aarch64 (eg., Pine64), luajit can't be installed by apt,
  # so build the aarch64 version from source.
  # LuaJIT uses a rolling release model and no longer provides tarballs
  # so clone from their git repository instead, which supports aarch64.

  cd /tmp/

  # Clean up any leftover directories from previous runs
  if [[ -e luajit ]]; then
    rm -rf luajit
  fi

  # Clone the official LuaJIT repository (defaults to the v2.1 branch as of 2026-07-22)
  git clone https://luajit.org/git/luajit.git

  cd luajit

  # Compile and install
  make
  make install

  # Clean up
  cd /tmp/
  rm -rf /tmp/luajit

else
  apt-get -y install luajit
fi
