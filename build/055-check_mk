#!/bin/bash
echo $0 > /var/www/html/userfiles/nems-build.cur

# Get the platform before removing php (as it requires PHP)
platform=$(/usr/local/bin/nems-info platform)

# Install standard build prerequisites
apt-get update
apt-get install -y build-essential gcc g++ make autoconf automake libtool
apt-get install -y php-net-socket
apt-get install -y sqlite3
apt-get install -y graphviz
apt-get install -y rrdtool
apt-get install -y librrd-dev
apt-get install -y libncurses5-dev
apt-get install -y libreadline-dev
apt-get install -y libxml2-dev
apt-get install -y libssl-dev

tmpdir=`mktemp -d -p /tmp/`

# --- DYNAMIC NAGIOS VERSION & SOURCE DETECTION ---
nagios_src=""

# Try binary execution to detect version
if [[ -x /usr/local/nagios/bin/nagios ]]; then
  detected_ver=$(/usr/local/nagios/bin/nagios -h 2>&1 | grep -oP 'Nagios Core \K[0-9.]+' | head -n 1)
  if [[ -n "${detected_ver}" && -d "/usr/src/nagios-${detected_ver}" ]]; then
    nagios_src="/usr/src/nagios-${detected_ver}"
    nagios_ver="${detected_ver}"
  fi
fi

# Fallback: Search /usr/src/ for the latest nagios-* source directory
if [[ -z "${nagios_src}" ]]; then
  nagios_src=$(find /usr/src -maxdepth 1 -type d -name "nagios-*" | sort -V | tail -n 1)
  if [[ -n "${nagios_src}" ]]; then
    nagios_ver=$(basename "${nagios_src}" | sed 's/nagios-//')
  fi
fi

# Final validation check
if [[ -z "${nagios_src}" || ! -d "${nagios_src}" ]]; then
  echo "Error: Unable to locate Nagios source tree in /usr/src! Aborting Livestatus build."
  exit 1
fi

echo "Building MK-Livestatus against Nagios Core ${nagios_ver} (${nagios_src})"
# --------------------------------------------------

ver="1.5.0p25"

# Download standalone MK-Livestatus tarball
wget -O ${tmpdir}/mk-livestatus.tar.gz https://packages.nemslinux.com/livestatus/mk-livestatus-${ver}.tar.gz
cd $tmpdir
tar xzf mk-livestatus.tar.gz
cd mk-livestatus-${ver}

# --- DYNAMIC HEADER PATCH FOR NAGIOS 4.5+ ---
# This makes mk-livestatus compatible with modern Nagios Core
cp -f ${nagios_src}/lib/*.h nagios4/
cp -f ${nagios_src}/include/*.h nagios4/
cp -f ${nagios_src}/base/*.h nagios4/

# Direct shared.h to use libnagios.h locally
sed -i '5s/.*/#include "libnagios.h"/' nagios4/shared.h
# ---------------------------------------------

./configure --with-nagios4
make
make install

# Place compiled livestatus.o binary where Nagios expects it
if [[ -f src/livestatus.o ]]; then
  mkdir -p /usr/local/nagios/bin
  cp -f src/livestatus.o /usr/local/nagios/bin/livestatus.o
  mkdir -p /usr/local/lib
  cp -f src/livestatus.o /usr/local/lib/livestatus.o
fi

# Create log for livestatus
touch /var/log/nagios/livestatus.log
chown nagios:nagios /var/log/nagios/livestatus.log

sleep 5

/bin/systemctl start nagios

printf "Waiting for socket to open..."
while [ ! -S /usr/local/nagios/var/rw/live.sock ]
do
  sleep 2
  printf "."
done
echo " done."

# Clean up build temp directory
rm -rf $tmpdir

exit 0
