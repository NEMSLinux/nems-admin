#!/bin/bash
echo $0 > /var/www/html/userfiles/nems-build.cur

# Install Python 3.9.2 into an isolated directory for Adagios
ADAGIOS_PY_DIR="/opt/python3.9"

if [[ ! -e "$ADAGIOS_PY_DIR/bin/python3" ]]; then
  echo "Building isolated Python 3.9.2 for Adagios..."
  cd /tmp/
  wget -q https://www.python.org/ftp/python/3.9.2/Python-3.9.2.tgz
  tar xzf Python-3.9.2.tgz
  cd Python-3.9.2
  ./configure --enable-optimizations --enable-loadable-sqlite-extensions --prefix="$ADAGIOS_PY_DIR"
  make -j$(nproc)
  make install
  rm -rf /tmp/Python-3.9.2*
fi

# No longer running update-alternatives as we want the core system to remain on the default 3.13.x

echo "Isolated Python 3.9.2 installed to $ADAGIOS_PY_DIR"
exit 0
